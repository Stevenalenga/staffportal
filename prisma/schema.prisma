// Uthabiti Africa Staff Portal - Database Schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js / NextAuth Models ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Enums ─────────────────────────────────────────────────────────────

enum UserRole {
  CEO
  OPERATIONS
  FINANCE
  HUMAN_RESOURCES
  PROGRAMME_MANAGER
  PROJECT_OFFICER
  STAFF
  CONSULTANT
  IT_ADMIN
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
  RESIGNED
}

enum ContractType {
  FULL_TIME
  PART_TIME
  CONTRACT
  CONSULTANT
  INTERN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  IN_MAINTENANCE
  RETIRED
  LOST
}

enum AssetCategory {
  LAPTOP
  DESKTOP
  MOBILE_PHONE
  FURNITURE
  PRINTER
  PROJECTOR
  NETWORK_EQUIPMENT
  SOFTWARE_LICENCE
  OTHER
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  FINANCE_APPROVED
  APPROVED
  DISBURSED
  REJECTED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  COMPASSIONATE
  STUDY
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ─── Organisation Structure ──────────────────────────────────────────────────

model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique
  description String?
  headId      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  head      User?       @relation("DepartmentHead", fields: [headId], references: [id])
  staff     User[]      @relation("DepartmentStaff")
  positions Position[]
}

model Position {
  id           String   @id @default(cuid())
  title        String
  departmentId String
  gradeLevel   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  users      User[]
}

// ─── User / Staff ────────────────────────────────────────────────────────────

model User {
  id               String           @id @default(cuid())
  employeeId       String?          @unique
  name             String?
  email            String           @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             UserRole         @default(STAFF)
  departmentId     String?
  positionId       String?
  employmentStatus EmploymentStatus @default(ACTIVE)
  contractType     ContractType?
  gender           Gender?
  phone            String?
  nationalId       String?
  dateOfBirth      DateTime?
  joinDate         DateTime?
  endDate          DateTime?
  bio              String?          @db.Text
  address          String?
  city             String?
  country          String           @default("Kenya")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Auth relations
  accounts Account[]
  sessions Session[]

  // Organisation relations
  department         Department?  @relation("DepartmentStaff", fields: [departmentId], references: [id])
  position           Position?    @relation(fields: [positionId], references: [id])
  departmentHeadOf   Department[] @relation("DepartmentHead")

  // HR relations
  emergencyContacts EmergencyContact[]
  documents         StaffDocument[]
  leaveRequests     Leave[]

  // Asset relations
  assignedAssets AssetAssignment[]

  // Expense relations
  expenses              Expense[]
  financeApprovedExpenses Expense[] @relation("ExpenseFinanceApprover")
  ceoApprovedExpenses     Expense[] @relation("ExpenseCeoApprover")
  disbursedExpenses       Expense[] @relation("ExpenseDisburser")

  // Project relations
  projectMemberships ProjectMember[]
  tasksAssigned      Task[]          @relation("TaskAssignee")
  tasksCreated       Task[]          @relation("TaskCreator")

  // Audit
  auditLogs AuditLog[]
}

model EmergencyContact {
  id           String  @id @default(cuid())
  userId       String
  name         String
  relationship String
  phone        String
  email        String?
  address      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StaffDocument {
  id         String   @id @default(cuid())
  userId     String
  name       String
  type       String
  url        String
  size       Int?
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Leave Management ────────────────────────────────────────────────────────

model Leave {
  id          String      @id @default(cuid())
  userId      String
  type        LeaveType
  startDate   DateTime
  endDate     DateTime
  days        Int
  reason      String?     @db.Text
  status      LeaveStatus @default(PENDING)
  approvedBy  String?
  approvedAt  DateTime?
  rejectedBy  String?
  rejectedAt  DateTime?
  notes       String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Asset Management ────────────────────────────────────────────────────────

model Asset {
  id               String        @id @default(cuid())
  assetTag         String        @unique
  classification   String?
  name             String
  category         AssetCategory
  brand            String?
  model            String?
  serialNumber     String?
  purchaseDate     DateTime?
  purchasePrice    Decimal?      @db.Decimal(12, 2)
  supplier         String?
  invoiceNumber    String?
  paymentReference String?
  warrantyExpiry   DateTime?
  status           AssetStatus   @default(AVAILABLE)
  condition        String?
  location         String?
  staffInCharge    String?
  notes            String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  assignments  AssetAssignment[]
  maintenance  AssetMaintenance[]
}

model AssetAssignment {
  id          String    @id @default(cuid())
  assetId     String
  userId      String
  assignedAt  DateTime  @default(now())
  returnedAt  DateTime?
  notes       String?

  asset Asset @relation(fields: [assetId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

model AssetMaintenance {
  id          String   @id @default(cuid())
  assetId     String
  date        DateTime
  type        String
  description String   @db.Text
  cost        Decimal? @db.Decimal(12, 2)
  vendor      String?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])
}

// ─── Expense Management ──────────────────────────────────────────────────────

model ExpenseCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  budgetLimit Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  expenses Expense[]
}

model Expense {
  id          String        @id @default(cuid())
  userId      String
  categoryId  String
  title       String
  description String?       @db.Text
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("KES")
  expenseDate DateTime
  projectName String?
  purpose     String?       @db.Text
  receiptUrl  String?
  status              ExpenseStatus @default(DRAFT)
  financeApprovedById String?
  financeApprovedAt   DateTime?
  ceoApprovedById     String?
  ceoApprovedAt       DateTime?
  disbursedById       String?
  disbursedAt         DateTime?
  rejectedById        String?
  rejectedAt          DateTime?
  rejectionReason     String?       @db.Text
  notes               String?       @db.Text
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user            User              @relation(fields: [userId], references: [id])
  category        ExpenseCategory   @relation(fields: [categoryId], references: [id])
  financeApprover User?             @relation("ExpenseFinanceApprover", fields: [financeApprovedById], references: [id])
  ceoApprover     User?             @relation("ExpenseCeoApprover", fields: [ceoApprovedById], references: [id])
  disburser       User?             @relation("ExpenseDisburser", fields: [disbursedById], references: [id])
  lineItems       ExpenseLineItem[]
}

model ExpenseLineItem {
  id            String    @id @default(cuid())
  expenseId     String
  itemDate      DateTime?
  specification String    @db.Text
  quantity      Decimal   @db.Decimal(10, 2)
  unitCost      Decimal   @db.Decimal(12, 2)
  cost          Decimal   @db.Decimal(12, 2)
  sortOrder     Int       @default(0)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

// ─── Project Management ──────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  name        String
  code        String        @unique
  description String?       @db.Text
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal?      @db.Decimal(14, 2)
  funder      String?
  objectives  String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members    ProjectMember[]
  milestones Milestone[]
  tasks      Task[]
  documents  ProjectDocument[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?   @db.Text
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

model Task {
  id          String       @id @default(cuid())
  projectId   String?
  milestoneId String?
  title       String
  description String?      @db.Text
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  assigneeId  String?
  creatorId   String
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project   Project?   @relation(fields: [projectId], references: [id])
  milestone Milestone? @relation(fields: [milestoneId], references: [id])
  assignee  User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator   User       @relation("TaskCreator", fields: [creatorId], references: [id])
}

model ProjectDocument {
  id        String   @id @default(cuid())
  projectId String
  name      String
  type      String
  url       String
  size      Int?
  uploadedAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
